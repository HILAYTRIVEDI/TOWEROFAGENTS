# Backend
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Private Storage bucket for uploaded workflow artifacts (created by migration
# 003). Server-side uploads use the service role key above.
DOCUMENTS_BUCKET=workflow-documents
# Max accepted upload size in bytes (default 25 MiB).
MAX_UPLOAD_BYTES=26214400

# LLM providers
AIML_API_KEY=
AIML_DEFAULT_MODEL=
# mock, aiml, or auto. auto resolves to AIML API in this deployment.
LLM_PROVIDER=aiml

# Embeddings: keep this dimension aligned with Supabase migrations.
# Use EMBEDDING_PROVIDER=aiml with AIML_API_KEY + EMBEDDING_MODEL for real RAG.
# EMBEDDING_PROVIDER=mock is deterministic local placeholder behavior only.
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=1536

# Band
# BAND_MODE=mock uses the in-process MockBandClient (no live agent).
# BAND_MODE=sdk runs the live `band-agent` coordinator that joins the room and
# replies to mentions. The remote agent must be a participant in the room.
BAND_MODE=mock
BAND_API_KEY=
BAND_AGENT_ID=
BAND_DEFAULT_ROOM_ID=

# Register each role as a separate Band Remote Agent. Roles without a complete
# UUID/API-key pair are skipped by the band-agent supervisor.
BAND_WORKFLOW_ROUTER_AGENT_ID=
BAND_WORKFLOW_ROUTER_API_KEY=
BAND_RAG_RETRIEVER_AGENT_ID=
BAND_RAG_RETRIEVER_API_KEY=
BAND_POLICY_GUARDIAN_AGENT_ID=
BAND_POLICY_GUARDIAN_API_KEY=
BAND_FINAL_DECISION_AGENT_ID=
BAND_FINAL_DECISION_API_KEY=
BAND_RESUME_JD_MATCHER_AGENT_ID=
BAND_RESUME_JD_MATCHER_API_KEY=
BAND_BIAS_REVIEWER_AGENT_ID=
BAND_BIAS_REVIEWER_API_KEY=
BAND_INTERVIEW_PLANNER_AGENT_ID=
BAND_INTERVIEW_PLANNER_API_KEY=
BAND_LEAD_QUALIFIER_AGENT_ID=
BAND_LEAD_QUALIFIER_API_KEY=
BAND_ENGINEERING_REVIEWER_AGENT_ID=
BAND_ENGINEERING_REVIEWER_API_KEY=

# Optional Band endpoint overrides (defaults shown). Normally leave blank.
# THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket
# THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=
THENVOI_REST_URL=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_ORG_ID=
