# Backend
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM providers
AIML_API_KEY=
AIML_DEFAULT_MODEL=
FEATHERLESS_API_KEY=
FEATHERLESS_DEFAULT_MODEL=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
# Model the live Band coordinator uses. Falls back to FEATHERLESS_DEFAULT_MODEL.
# MUST support OpenAI tool calling (the Band adapter replies via platform tools).
FEATHERLESS_TOOL_MODEL=
LLM_PROVIDER=mock

# Embeddings: keep this dimension aligned with Supabase migrations.
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=1536

# Band
# BAND_MODE=mock uses the in-process MockBandClient (no live agent).
# BAND_MODE=sdk runs the live `band-agent` coordinator that joins the room and
# replies to mentions. The remote agent must be a participant in the room.
BAND_MODE=mock
BAND_API_KEY=
BAND_AGENT_ID=
BAND_DEFAULT_ROOM_ID=
# Optional Band endpoint overrides (defaults shown). Normally leave blank.
# THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket
# THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=
THENVOI_REST_URL=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

